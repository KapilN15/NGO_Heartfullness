# ─────────────────────────────────────────────────────────
# Heartfulness NGO – Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# ── LOCAL PostgreSQL ──────────────────────────────────────
# Used automatically when DATABASE_URL is NOT set.
DB_USER=postgres
DB_PASSWORD=kapiln@15
DB_HOST=localhost
DB_PORT=5432
DB_NAME=heartfulness

# ── RENDER PostgreSQL ────────────────────────────────────
# Render sets DATABASE_URL automatically – DO NOT set it
# manually here unless you are overriding for a specific reason.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
